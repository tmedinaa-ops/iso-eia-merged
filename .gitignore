# Data
# The merged dataset will eventually be released through an academic data
# archive (Zenodo / ICPSR). Until then, the four files needed for `make all`
# are whitelisted below so clones can reproduce the analysis and dashboard
# end-to-end without a separate download step. Everything else in data/
# (raw LBNL / EIA / ISO workbooks, pipeline intermediates) stays ignored.
data/*
!data/.gitkeep
!data/raw/
!data/processed/
!data/ISO_EIA_Merged_v5.csv
!data/ISO_EIA_Merged_v7.csv
!data/EIA_860_All_Generators.csv
!data/TIQ_Analysis_Clean.csv
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Build artifacts (dashboard HTML, rendered analysis, cached GeoJSON)
build/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.Python

# R
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj
*_files/
*_cache/
*.html
*.log

# Keep the dashboard HTML template (it is source, not a build artifact)
!src/python/dashboard/dashboard_template.html

# Output artifacts from R Markdown
*.pdf
*.png
*.jpg
*.jpeg

# macOS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*~
